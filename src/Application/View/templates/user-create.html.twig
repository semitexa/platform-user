<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create User — Semitexa Platform</title>
    <link rel="stylesheet" href="/assets/platform-user/css/users.css">
    <script src="/assets/platform-wm/js/wm-sdk.js"></script>
</head>
<body>
    <div class="page-container">
        <div class="page-header">
            <h1>Create User</h1>
        </div>

        <form id="create-user-form" class="profile-form">
            <div class="form-field">
                <label for="uname">Name</label>
                <input type="text" name="uname" id="uname" required>
            </div>
            <div class="form-field">
                <label for="email">Email</label>
                <input type="email" name="email" id="email" required>
            </div>
            <div class="form-field">
                <label for="password">Password</label>
                <input type="password" name="password" id="password" required minlength="8">
            </div>
            <div class="form-actions">
                <button type="button" class="btn btn-ghost" id="cancel-btn">Cancel</button>
                <button type="submit" class="btn btn-primary">Create User</button>
            </div>
            <div id="error-msg" class="error-msg" style="display:none;"></div>
        </form>
    </div>

    <script type="module" src="/assets/platform-user/js/user-create.js"></script>
</body>
</html>
